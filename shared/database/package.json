{
	"name": "@riceball/db",
	"author": "Alexis Vielma",
	"license": "MIT",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsup && (pnpm run build:cache || echo 'Cache generation skipped, requires Node >=22')",
		"build:cache": "mikro-orm cache:generate --combined --ts --config ./src/mikro-orm.config.ts",
		"dev": "tsup --watch",
		"start": "node ./dist/index.js",
		"check-types": "tsc --noEmit"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./zod": {
			"import": {
				"types": "./dist/zod.d.ts",
				"default": "./dist/zod.js"
			},
			"require": {
				"types": "./dist/zod.d.cts",
				"default": "./dist/zod.cjs"
			}
		},
		"./custom": {
			"import": {
				"types": "./dist/custom.d.ts",
				"default": "./dist/custom.js"
			},
			"require": {
				"types": "./dist/custom.d.cts",
				"default": "./dist/custom.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@mikro-orm/core": "^7.0.6",
		"@mikro-orm/decorators": "^7.0.6",
		"@mikro-orm/migrations-mongodb": "^7.0.6",
		"@mikro-orm/mongodb": "^7.0.6",
		"@mikro-orm/reflection": "^7.0.6",
		"@riceball/logger": "workspace:*",
		"dotenv": "17.3.1",
		"ioredis": "5.10.1",
		"reflect-metadata": "0.2.2",
		"tsup": "^8.5.1",
		"tsyringe": "4.10.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@mikro-orm/cli": "^7.0.6",
		"@riceball/ts-config": "workspace:*",
		"@types/node": "25.5.0",
		"tsx": "^4.20.6",
		"typescript": "^6.0.2"
	},
	"mikro-orm": {
		"tsLoader": "tsx",
		"configPaths": [
			"./src/mikro-orm.config.ts",
			"./dist/mikro-orm.config.js"
		]
	}
}